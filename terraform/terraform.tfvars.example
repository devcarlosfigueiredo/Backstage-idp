# terraform.tfvars — Exemplo de configuração (NÃO commitar com valores reais)
# Copiar para terraform.tfvars.local e preencher com os valores reais

aws_region   = "eu-west-1"
environment  = "production"
project_name = "platform-portal"

# EKS
node_instance_type = "t3.large"    # production: t3.large ou m5.large
allowed_cidr_blocks = [
  "10.0.0.0/8",     # rede interna
  "203.0.113.0/24", # VPN da empresa
]

# RDS
db_instance_class = "db.t4g.medium"  # production: db.t4g.medium ou db.m6g.large

# IAM
platform_admin_role_arn = "arn:aws:iam::123456789012:role/PlatformAdminRole"

# Backstage Image
backstage_image_tag = "1.2.0"
